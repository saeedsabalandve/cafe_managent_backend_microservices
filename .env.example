# .env.example
# Copy to .env and fill in values

NODE_ENV=development

# API Gateway
API_GATEWAY_PORT=3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT
JWT_PUBLIC_KEY_PATH=/keys/jwt-public.pem
ACCESS_TOKEN_EXPIRY=900
REFRESH_TOKEN_EXPIRY=604800

# Databases
POSTGRES_MENU_URI=postgresql://cafe_admin:dev_password_2020@postgres-menu:5432/menu_db
POSTGRES_INVENTORY_URI=postgresql://cafe_admin:dev_password_2020@postgres-inventory:5432/inventory_db
MONGO_AUTH_URI=mongodb://mongo-auth:27017/auth_db
MONGO_ORDER_URI=mongodb://mongo-order:27017/order_db
REDIS_URL=redis://redis:6379
CLICKHOUSE_URL=http://clickhouse:8123

# Service URLs
AUTH_SERVICE_URL=http://auth-service:3001
MENU_SERVICE_URL=http://menu-service:3002
ORDER_SERVICE_URL=http://order-service:3003
INVENTORY_SERVICE_URL=http://inventory-service:3004
ANALYTICS_SERVICE_URL=http://analytics-service:3005

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
